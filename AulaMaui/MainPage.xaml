<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AulaMaui.MainPage"
             Title=""
             BackgroundColor="Brown">

    <ScrollView>
        <VerticalStackLayout >
            <StackLayout Spacing="40" Margin="40,40,40,40" VerticalOptions="Center">
                <Label Text="Nome do macaco:"/>
                <Entry Placeholder="Digite o nome"
                       x:Name="et_nome"/>
                <Label Text="Especie do macaco:"/>
                <Entry Placeholder="Digite a especie"
                       x:Name="et_especie"/>
                <Label Text="Doença do macaco:"/>
                <Entry Placeholder="Digite a doença"
                       x:Name="et_doenca"/>
                <Label Text="Imagem do macaco:"/>
                <Entry Placeholder="Digite a Imagem"
                       x:Name="et_imagem"/>
                <Button Clicked="novoMacaco" Text="Cadastrar Macaco"/>
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
